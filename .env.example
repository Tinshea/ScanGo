# Copiez ce fichier en « .env » et renseignez les valeurs réelles.
# Le fichier .env est ignoré par Git : aucun secret ne doit être commité.

# --- Obligatoire ---------------------------------------------------------

# Chaîne de connexion MongoDB.
MONGO_URI=mongodb://mongo:27017/scango

# Clé de signature des jetons JWT — 32 caractères minimum.
# Le serveur refuse de démarrer en dessous de cette longueur : une clé vide
# produirait des jetons signés avec une clé nulle, donc forgeables.
# Génération : openssl rand -base64 48
JWT_SECRET=

# --- Optionnel -----------------------------------------------------------

# Cloudinary, pour l'upload des images de profil et bannières.
# Absent, l'upload renvoie 503 mais le reste de l'application fonctionne.
CLOUDINARY_URL=

# Origines autorisées par le CORS, séparées par des virgules.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Filtre de contenu MangaDex, séparé par des virgules.
# Valeurs possibles : safe, suggestive, erotica, pornographic.
# Attention : sans ce paramètre, l'API MangaDex renvoie par défaut
# safe + suggestive + erotica.
ALLOWED_CONTENT_RATINGS=safe,suggestive

# UUID de tags MangaDex à exclure, séparés par des virgules.
# Par défaut : Gore et Sexual Violence.
# EXCLUDED_TAGS=b29d6a3d-1569-4e7a-8caf-7557bc92cd5d,97893a4c-12af-4dac-b6be-0dffb353568e

# Port d'écoute du backend (Render le fournit automatiquement).
# PORT=8080
